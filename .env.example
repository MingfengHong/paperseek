# PaperSeek example environment file.
# Copy to .env for local CLI use, or set these variables in your shell.
# Do not commit real API keys.

# LLM provider settings (required).
# Choose one provider and fill in the corresponding variables.
# DeepSeek example:
LLM_PROVIDER=deepseek
LLM_API_TYPE=openai_chat
LLM_MODEL=deepseek-v4-flash
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=

# Other provider examples (uncomment the block you want to use):
# CSTCloud:
# LLM_PROVIDER=cstcloud
# LLM_API_TYPE=openai_chat
# LLM_MODEL=DeepSeek-V4-Flash
# LLM_BASE_URL=https://uni-api.cstcloud.cn/v1
# LLM_API_KEY=

# ModelScope API-Inference:
# LLM_PROVIDER=modelscope
# LLM_API_TYPE=openai_chat
# LLM_MODEL=Qwen/Qwen3-235B-A22B-Instruct-2507
# LLM_BASE_URL=https://api-inference.modelscope.cn/v1
# LLM_API_KEY=

# Data source API keys (optional but recommended).
# OpenAlex can be used anonymously; a free API key gives more stable access.
OPENALEX_API_KEY=
OPENALEX_EMAIL=

# Crossref public API usually needs only a polite-pool email.
CROSSREF_EMAIL=

# Web of Science Starter requires an approved Clarivate API key.
WOS_API_KEY=

# Search defaults (optional).
SEARCH_FIELD=
# Optional OpenAlex Field IDs, labels, or URLs; use semicolons for multiple values.
# Examples: DISCIPLINE_FIELDS=17;14
#           DISCIPLINE_FIELDS=Computer Science;Business, Management and Accounting
DISCIPLINE_FIELDS=
