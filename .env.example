# PaperSeek example environment file.
# Copy to .env for local CLI, Web UI, Docker, or MCP use.
# Do not commit real API keys.
#
# Minimal setup:
# - By default PaperSeek uses OpenAI + OpenAlex.
# - OpenAlex can run anonymously, but an OpenAlex key is recommended for stable use.
# - If you use Ollama, LLM_API_KEY can stay empty.

LLM_API_KEY=
# OPENALEX_API_KEY=

# ---------------------------------------------------------------------------
# Common provider examples. Uncomment one block if you do not use default OpenAI.
# ---------------------------------------------------------------------------

# DeepSeek / OpenAI-compatible:
# LLM_PROVIDER=deepseek
# LLM_API_TYPE=openai_chat
# LLM_MODEL=deepseek-v4-flash
# LLM_BASE_URL=https://api.deepseek.com

# CSTCloud / OpenAI-compatible:
# LLM_PROVIDER=cstcloud
# LLM_API_TYPE=openai_chat
# LLM_MODEL=deepseek-v4-flash
# LLM_BASE_URL=https://uni-api.cstcloud.cn/v1

# ModelScope API-Inference / OpenAI-compatible:
# LLM_PROVIDER=modelscope
# LLM_API_TYPE=openai_chat
# LLM_MODEL=Qwen/Qwen3-235B-A22B-Instruct-2507
# LLM_BASE_URL=https://api-inference.modelscope.cn/v1

# Local Ollama:
# LLM_PROVIDER=ollama
# LLM_API_TYPE=openai_chat
# LLM_MODEL=qwen3:8b
# LLM_BASE_URL=http://127.0.0.1:11434/v1
# LLM_API_KEY=

# NVIDIA NIM example:
# LLM_PROVIDER=nvidia
# LLM_API_TYPE=openai_chat
# LLM_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5
# LLM_BASE_URL=https://integrate.api.nvidia.com/v1
# LLM_API_KEY=

# OpenRouter example:
# LLM_PROVIDER=openrouter
# LLM_API_TYPE=openai_chat
# LLM_MODEL=openai/gpt-5.4-mini
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=

# ---------------------------------------------------------------------------
# Optional source keys and polite-pool metadata.
# ---------------------------------------------------------------------------

# DATA_SOURCE=openalex
# OPENALEX_EMAIL=
# SEMANTIC_SCHOLAR_API_KEY=
# PUBMED_EMAIL=
# PUBMED_TOOL=paperseek
# PUBMED_API_KEY=
# SERPER_API_KEY=
# SERPER_API_KEYS=
# CROSSREF_EMAIL=
# WOS_API_KEY=
# WOS_DB=WOS

# ---------------------------------------------------------------------------
# Advanced search controls. Code defaults are used when these stay commented.
# ---------------------------------------------------------------------------

# SEARCH_FIELD=
# DISCIPLINE_FIELDS=
# TARGET_MIN/TARGET_MAX guide query refinement; TARGET_MAX is not a hard display cap.
# MAX_ITERATIONS starts at 5, with a bounded adaptive extension for empty/too small/too large pools.
# TARGET_MIN=5
# TARGET_MAX=50
# MAX_ITERATIONS=5
# EXPAND_CITATIONS=true
# FETCH_ABSTRACTS=false
# CITATION_SEED_COUNT=30
# CITATION_PER_SEED=4
# CITATION_MAX_RECORDS=160
# CITATION_DEPTH=2
# RANKING_BATCH_SIZE=8
# RANKING_CONCURRENCY=16
# RANKING_CONCURRENCY retries failed LLM ranking batches with 16 -> 8 -> 4 by default.
# RANKING_LLM_TIMEOUT_SECONDS applies only to LLM result-ranking batches; timed-out ranking falls back to local pre-ranking.
# RANKING_CANDIDATE_LIMIT is the LLM scoring cap after pre-ranking; final display keeps at least top 50 and all score>=5 when larger.
# RANKING_CANDIDATE_LIMIT=256
# LLM_MAX_TOKENS=2048
# LLM_TIMEOUT_SECONDS=180
# RANKING_LLM_TIMEOUT_SECONDS=60

# ---------------------------------------------------------------------------
# Advanced retrieval and pre-ranking controls.
# Community edition defaults to local pure-Python hashing/BM25/RRF.
# Configure external embedding/reranker endpoints only if you need them.
# ---------------------------------------------------------------------------

# RETRIEVAL_POOL_MAX=3000
# RETRIEVAL_POOL_MIN=5
# RETRIEVAL_LANE_LIMIT=1000
# RETRIEVAL_RRF_K=60
# RETRIEVAL_EMBEDDING_PROVIDER=local
# RETRIEVAL_EMBEDDING_MODEL=qwen3-embedding:8b,bge-large-zh:latest
# RETRIEVAL_EMBEDDING_BASE_URL=
# RETRIEVAL_EMBEDDING_API_KEY=
# RETRIEVAL_RERANKER_PROVIDER=
# RETRIEVAL_RERANKER_MODEL=qwen3-reranker:8b
# RETRIEVAL_RERANKER_BASE_URL=
# RETRIEVAL_RERANKER_API_KEY=
# RETRIEVAL_CROSSREF_ENRICHMENT=false

# NVIDIA NIM retrieval examples:
# RETRIEVAL_EMBEDDING_PROVIDER=nvidia
# RETRIEVAL_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5
# RETRIEVAL_EMBEDDING_BASE_URL=https://integrate.api.nvidia.com/v1
# RETRIEVAL_RERANKER_PROVIDER=nvidia
# RETRIEVAL_RERANKER_MODEL=nv-rerank-qa-mistral-4b:1
# RETRIEVAL_RERANKER_BASE_URL=https://ai.api.nvidia.com/v1/retrieval/nvidia/reranking

# OpenRouter retrieval examples:
# RETRIEVAL_EMBEDDING_PROVIDER=openrouter
# RETRIEVAL_EMBEDDING_MODEL=openai/text-embedding-3-small
# RETRIEVAL_EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
# RETRIEVAL_RERANKER_PROVIDER=openrouter
# RETRIEVAL_RERANKER_MODEL=jinaai/jina-reranker-v2-base-multilingual
# RETRIEVAL_RERANKER_BASE_URL=https://openrouter.ai/api/v1

# ---------------------------------------------------------------------------
# Local history. Keys are never stored in this SQLite database.
# ---------------------------------------------------------------------------

# PAPERSEEK_HISTORY_ENABLED=true
# PAPERSEEK_TIMEZONE=Asia/Shanghai
# PAPERSEEK_DATA_DIR=~/.paperseek
# PAPERSEEK_HISTORY_DB=~/.paperseek/paperseek.db
